# ===========================================
# Environment Configuration Template
# ===========================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# ===========================================

# ===========================================
# DATABASE CONFIGURATION
# ===========================================

# Oracle Database
ORACLE_USER=your_oracle_username
ORACLE_PASSWORD=your_oracle_password
ORACLE_HOST=your_oracle_host
ORACLE_PORT=1521
ORACLE_SERVICE=your_service_name
# Connection string format: host:port/service
ORACLE_CONN_STRING=your_host:1521/your_service

# SQL Server
SQL_SERVER_USER=your_sql_username
SQL_SERVER_PASSWORD=your_sql_password
SQL_SERVER_HOST=your_sql_server_host
SQL_SERVER_DATABASE=your_database_name
SQL_SERVER_CONN_STRING=Server=your_server;Database=your_db;User Id=your_user;Password=your_password;

# PostgreSQL (if used)
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=your_database

# ===========================================
# API KEYS & SECRETS
# ===========================================

# Reddit API (for _API PRAW reddit.py)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=your_user_agent

# Google API (for client-secrets.json usage)
GOOGLE_API_KEY=your_google_api_key
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Other API Keys
API_KEY=your_api_key
API_SECRET=your_api_secret

# ===========================================
# EMAIL CONFIGURATION
# ===========================================

# SMTP Settings (for email.py, reminders)
SMTP_SERVER=smtp.yourcompany.com
SMTP_PORT=587
SMTP_USER=your_email@yourcompany.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=your_email@yourcompany.com

# ===========================================
# APPLICATION SETTINGS
# ===========================================

# File Paths
BASE_DIR=C:/Users/prasa/OneDrive/Documents/Legal_Professional/Python programming
DATA_DIR=your_data_directory
OUTPUT_DIR=your_output_directory

# DMV Locations (for DMV scripts)
DMV_LOCATION=your_dmv_location
DMV_API_URL=your_dmv_api_url

# Application Environment
ENV=development  # development, staging, production
DEBUG=True
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# ===========================================
# WEB SCRAPING
# ===========================================

# Selenium Settings
SELENIUM_HEADLESS=False
SELENIUM_TIMEOUT=30

# User Agents
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# ===========================================
# MACHINE LEARNING
# ===========================================

# Model Paths (for BERT, PCA, etc.)
MODEL_DIR=your_model_directory
BERT_MODEL_PATH=your_bert_model_path

# ===========================================
# AWS/Cloud (if applicable)
# ===========================================

AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_bucket_name

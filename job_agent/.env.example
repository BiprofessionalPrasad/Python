# Job Agent Configuration
# Copy this file to .env and update the values

# Flask Configuration
SECRET_KEY=your-secret-key-here
FLASK_ENV=development
FLASK_DEBUG=True

# Database Configuration
# SQLite (default)
DATABASE_URL=sqlite:///job_agent.db

# PostgreSQL (uncomment to use)
# DATABASE_URL=postgresql://user:password@localhost/jobagent

# MySQL (uncomment to use)
# DATABASE_URL=mysql+pymysql://user:password@localhost/jobagent

# Scraping Configuration
# Delay between requests (in seconds) to avoid rate limiting
SCRAPER_DELAY=2

# Maximum retries for failed requests
SCRAPER_MAX_RETRIES=3

# Timeout for HTTP requests (in seconds)
SCRAPER_TIMEOUT=30

# Email Notifications (optional)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# NOTIFICATION_EMAIL=your-email@gmail.com